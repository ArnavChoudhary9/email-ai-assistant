# Copy this file to .env and fill in real values. Never commit .env.

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Telegram — create a bot via @BotFather and paste the token here.
# TELEGRAM_CHAT_ID is now OPTIONAL. If empty, the bot auto-captures your
# chat_id the first time you /start it. If set, it's seeded as the owner.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Fernet key used to encrypt account passwords at rest. Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep this safe — changing it makes existing stored passwords undecryptable.
APP_ENCRYPTION_KEY=

# Timezone for interpreting LLM-extracted dates/times. IANA name.
# Default Asia/Kolkata. Override if you're elsewhere.
APP_TIMEZONE=Asia/Kolkata

# Paths (override if you want the db/logs elsewhere)
EMAIL_INTEL_DB_PATH=data/email_intel.db
EMAIL_INTEL_LOG_PATH=logs/email_intel.log
EMAIL_INTEL_ACCOUNTS_PATH=config/accounts.yaml

# Scheduling
POLL_INTERVAL_MINUTES=5

# Model tiers (see PRD §18)
TRIAGE_MODEL=google/gemini-2.0-flash-001
EXTRACTION_MODEL=anthropic/claude-sonnet-4.5
FALLBACK_MODEL=openai/gpt-4o-mini

# Google Calendar — opt-in. If the client-secrets file isn't present, calendar
# sync is skipped and the rest of the pipeline keeps running.
#
# One-time setup:
#   1. https://console.cloud.google.com/apis/credentials
#   2. Create OAuth client ID → Application type: "Desktop app"
#   3. Download the JSON and save it to the path below
#   4. On first run the app opens a browser for consent, then caches a
#      refresh token at GOOGLE_TOKEN_PATH.
GOOGLE_CLIENT_SECRETS_PATH=config/google_client_secret.json
GOOGLE_TOKEN_PATH=data/google_token.json
GOOGLE_CALENDAR_ID=primary

# Deferred — not wired yet
GMAIL_CLIENT_ID=
GMAIL_SECRET=
